# OS / editor
.DS_Store
.Rhistory
Thumbs.db
*~
.idea/
.vscode/

# Python (updater pipeline)
__pycache__/
*.py[cod]
.venv/
venv/
env/
*.egg-info/

# Scraper intermediate output (raw, not served) — keep dir, ignore contents
data/scraped/*
!data/scraped/.gitkeep

# Node (none expected; guard anyway)
node_modules/
npm-debug.log*

# Logs / temp
*.log
tmp/

# Orchestration runtime artifacts (transient handoff state; not source)
orchestration/STOP
orchestration/outbox/*
!orchestration/outbox/.gitkeep
orchestration/logs/*
!orchestration/logs/.gitkeep
orchestration/inbox/.processed/*
# review work area (transient; accepted files get assembled into the live tree)
review/pending/*
!review/pending/.gitkeep
review/rejected/*
!review/rejected/.gitkeep
review/accepted/*
!review/accepted/.gitkeep

# Preview tooling (local only)
.claude/
